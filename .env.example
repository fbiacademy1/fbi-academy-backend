DATABASE_URL="file:./dev.db"
PORT=4000
JWT_SECRET="change-this-to-a-long-random-string"

# Shared secret between this backend and the WordPress plugin.
# Must match the "TeamSync Shared Secret" field in WP Admin > Settings > TeamSync Sync.
WORDPRESS_SYNC_SECRET="change-this-too"

# Your WordPress site's REST API base, e.g. https://yourclub.com/wp-json/teamsync/v1
WORDPRESS_API_BASE="https://yourclub.com/wp-json/teamsync/v1"
